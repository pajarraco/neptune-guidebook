{
  "name": "neptune-guidebook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently --prefix-colors \"blue,magenta,green\" --names \"APP,ADMIN,API\" \"npm:dev:app\" \"npm:dev:admin\" \"npm:dev:server\"",
    "dev:app": "vite",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:server": "NODE_ENV=development LOCALES_DIR=./public/locales node --env-file=.env.local scripts/server.mjs",
    "fetch-data": "LOCALES_DIR=./public/locales node scripts/fetch-sheet-data.mjs",
    "build:guest": "tsc -b && vite build",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build": "prettier --write . && eslint . && npm run build:guest && npm run build:admin",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "sh scripts/start.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "dotenv": "^17.3.1",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "i18next": "^25.10.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^16.6.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1"
  }
}

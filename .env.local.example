# Google Sheets Integration (for local testing)
# Copy this file to .env.local and fill in your values

# OPTION 1 (RECOMMENDED): Path to service account JSON file
# Download the JSON key file from Google Cloud Console and save it locally
# Then uncomment and set the path below (relative to project root or absolute path)
# GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# OPTION 2: Service account credentials as JSON string (for CI/CD)
# Paste the entire JSON as a single line (only use if Option 1 doesn't work)
# GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Your Google Sheet ID (from the URL)
GOOGLE_SHEET_ID=your_sheet_id_here

# Languages to fetch (comma-separated sheet names)
# Each language should have its own sheet in the Google Spreadsheet
# Default: en
LANGUAGES=en,es,fr
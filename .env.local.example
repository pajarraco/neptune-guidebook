# =============================================================================
# Local development environment.
# Copy to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Guest app (Vite — baked into the bundle at build time)
# -----------------------------------------------------------------------------
# Access code shown in the entry modal. Also used by the server to gate
# /locales/* requests (server reads ACCESS_CODE; falls back to VITE_CODE).
VITE_CODE=your-access-code

# Apartment / unit number shown in the UI.
VITE_APARTMENT_NUMBER=123

# Comma-separated language codes. Each must have a matching sheet tab and
# a corresponding {lang}.json file at runtime.
VITE_LANGUAGES=en,es,fr,it

# Comma-separated setting names (e.g., "config" for config.json).
VITE_SETTINGS=config

# -----------------------------------------------------------------------------
# Admin panel (/admin) — Google OAuth sign-in
# -----------------------------------------------------------------------------
# Google OAuth 2.0 Web Client ID. Create one at:
#   https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000 (and your prod URL) to "Authorized JS origins".
# This value is BAKED into the admin bundle (it's a public identifier).
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Same value as above — used by the server to verify ID tokens.
GOOGLE_OAUTH_CLIENT_ID=

# Comma-separated list of Google account emails allowed to sign in.
ALLOWED_EMAILS=you@gmail.com

# Random secret used to HMAC-sign session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Google Sheets integration
# -----------------------------------------------------------------------------
# OPTION 1 (RECOMMENDED for local dev): Path to service account JSON file.
# Download the key file from Google Cloud Console and save it locally.
# GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# OPTION 2 (RECOMMENDED for CI/CD / Coolify): Service account credentials as
# a single-line JSON string.
# GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Spreadsheet ID (from the Sheet URL).
GOOGLE_SHEET_ID=your_sheet_id_here

# Languages the fetch script reads from the spreadsheet.
LANGUAGES=en,es,fr,it

# -----------------------------------------------------------------------------
# Server runtime (only relevant when running src/server/server.mjs locally)
# -----------------------------------------------------------------------------
# Where the server reads/writes locale JSON files. Defaults to dist/locales.
# For local dev with `npm run dev`, locales are served from public/locales
# automatically and this is unused.
# LOCALES_DIR=./public/locales

# Where the server reads/writes settings JSON files. Defaults to dist/settings.
# For local dev with `npm run dev`, set to ./public/settings.
SETTINGS_DIR=./public/settings

# Settings the server manages (comma-separated). Falls back to VITE_SETTINGS.
SETTINGS=config

# Server gates /locales/*. If unset, falls back to VITE_CODE.
# ACCESS_CODE=your-access-code

# Port the production server listens on.
# PORT=3000
